<?xml version="1.0" encoding="UTF-8"?>
<!--
  Gulfshine Travel - IIS config.
  Deploy: the CONTENTS of redesign/ go into the web root.
-->
<configuration>
  <system.webServer>

    <!-- Serve index.html for directory requests -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Custom 404 page -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
    </httpErrors>

    <!-- Keep development files out of the public site -->
    <security>
      <requestFiltering>
        <fileExtensions>
          <add fileExtension=".md" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <!-- http -> https, so form submissions and browsing are always encrypted -->
        <rule name="Force HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://gulfshineservices.us/{R:1}" redirectType="Permanent" />
        </rule>
        <!-- www -> apex (gulfshineservices.us, no www) -->
        <rule name="Strip WWW" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.gulfshineservices\.us$" />
          </conditions>
          <action type="Redirect" url="https://gulfshineservices.us/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

    <!-- Light caching for static assets -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>

  </system.webServer>
</configuration>
